<!DOCTYPE html>
<html lang="ja">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>スクリーン生地ラベル</title>
  <style>
    /* ===== 用紙: 110 × 350 mm ===== */
    @page {
      size: 110mm 350mm;
      margin: 0;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      background: #fff;
    }

    * {
      box-sizing: border-box;
    }

    .label {
      width: 110mm;
      height: 350mm;
      margin: 0 auto;
      padding: 7mm 8mm;
      background: #fff;
      color: #000;
      font-family: Arial, Helvetica, "Yu Gothic", "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ===== ミシン目(点線) ===== */
    .perf {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 1mm;
    }

    .perf i {
      width: 1.7mm;
      height: 1.7mm;
      border-radius: 50%;
      background: #111;
      display: block;
    }

    /* ===== ヘッダー ===== */
    .head {
      margin-top: 5mm;
    }

    .head .code {
      font-size: 13mm;
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.3mm;
    }

    .head .name {
      font-size: 3.7mm;
      font-weight: 600;
      margin-top: 1mm;
      letter-spacing: 0.1mm;
    }

    /* ===== 仕様表 ===== */
    table.spec {
      border-collapse: collapse;
      margin-top: 4mm;
      width: 100%;
    }

    table.spec td {
      font-size: 3mm;
      line-height: 4.3mm;
      padding: 0;
      vertical-align: top;
      white-space: nowrap;
    }

    table.spec .en {
      font-weight: 800;
      width: 18mm;
    }

    table.spec .jp {
      font-weight: 500;
      width: 24mm;
    }

    table.spec .v1 {
      font-weight: 600;
      width: 23mm;
    }

    table.spec .v2 {
      font-weight: 600;
    }

    /* ===== バーコード ===== */
    .barcode-wrap {
      margin-top: 5mm;
      text-align: center;
    }

    .barcode-wrap svg {
      width: 90mm;
      height: 15mm;
    }

    .barcode-text {
      font-size: 2.9mm;
      letter-spacing: 0.6mm;
      margin-top: 0.5mm;
    }

    /* ===== ケア表示 ===== */
    .care {
      margin-top: 3mm;
      border-top: 0.3mm solid #000;
      padding-top: 1.5mm;
    }

    .care .en {
      font-size: 1.9mm;
      color: #000;
      text-align: center;
      letter-spacing: 0.1mm;
    }

    .care .icons {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 3mm;
      margin: 1mm 0;
    }

    .care .icons svg {
      width: 7mm;
      height: 7mm;
      display: block;
    }

    .care .jp {
      font-size: 1.7mm;
      color: #000;
      text-align: center;
      letter-spacing: 0.1mm;
    }

    /* ===== QR + 防炎ボックス ===== */
    .mid {
      display: flex;
      gap: 5mm;
      margin-top: 3mm;
      align-items: stretch;
    }

    .qr {
      width: 36mm;
      position: relative;
    }

    .qr img,
    .qr canvas {
      width: 36mm;
      height: 36mm;
      display: block;
      image-rendering: pixelated;
    }

    .qr .logo {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 9mm;
      height: 9mm;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .qr .logo svg {
      width: 8mm;
      height: 8mm;
    }

    .bohen {
      flex: 1;
      border: 0.4mm solid #000;
      padding: 1.5mm;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .bohen .mark {
      height: 11mm;
      display: flex;
      align-items: center;
    }

    .bohen .mark svg {
      height: 10mm;
      width: auto;
    }

    .bohen .t1 {
      font-size: 2.7mm;
      font-weight: 800;
      letter-spacing: 0.4mm;
      margin-bottom: 1mm;
    }

    .bohen .div {
      width: 100%;
      border-top: 0.3mm solid #000;
      margin: 1mm 0;
    }

    .bohen .t2 {
      font-size: 2.2mm;
      font-weight: 600;
    }

    .bohen .num {
      font-size: 3.4mm;
      font-weight: 800;
      letter-spacing: 0.3mm;
      margin-top: 0.5mm;
    }

    .bohen .t3 {
      font-size: 2.1mm;
      margin-top: 1mm;
    }

    /* ===== フッター ===== */
    .foot {
      margin-top: 4mm;
      text-align: center;
      line-height: 3.6mm;
    }

    .foot .company {
      font-size: 2.7mm;
      font-weight: 700;
    }

    .foot .addr {
      font-size: 2.4mm;
    }

    .foot .design {
      font-size: 2.7mm;
      font-weight: 700;
      margin-top: 1mm;
      letter-spacing: 0.2mm;
    }

    /* ===== 余白スペーサ ===== */
    .spacer {
      flex: 1 1 auto;
      min-height: 6mm;
    }

    /* ===== ハトメ(円) ===== */
    .eyelets {
      display: flex;
      justify-content: space-between;
      padding: 0 4mm;
      margin-bottom: 4mm;
    }

    .eyelets i {
      width: 5.4mm;
      height: 5.4mm;
      border-radius: 50%;
      border: 0.7mm solid #111;
      display: block;
      box-shadow: inset 0 0 0 0.7mm #fff, inset 0 0 0 1.4mm #111;
    }

    /* 二重円(ハトメ)表現 */
    .eyelets i {
      position: relative;
      box-shadow: none;
    }

    .eyelets i::after {
      content: "";
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 2.6mm;
      height: 2.6mm;
      border-radius: 50%;
      border: 0.6mm solid #111;
    }

    @media print {

      html,
      body {
        width: 110mm;
        height: 350mm;
      }

      .label {
        margin: 0;
      }
    }
  </style>
</head>

<body>
  <div class="label">
    <!-- 上ミシン目 -->
    <div class="perf" id="perfTop"></div>

    <!-- ヘッダー -->
    <div class="head">
      <div class="code" id="fCode">DP</div>
      <div class="name" id="fName">ダブルレイヤーポリエステル生地</div>
    </div>

    <!-- 仕様表 -->
    <table class="spec">
      <tr>
        <td class="en">Fabric</td>
        <td class="jp">生地</td>
        <td class="v1" colspan="2" id="sFabric">DP</td>
      </tr>
      <tr>
        <td class="en">Size</td>
        <td class="jp">サイズ</td>
        <td class="v1" colspan="2" id="sSize">W:2800×H:3000</td>
      </tr>
      <tr>
        <td class="en">layer</td>
        <td class="jp">層</td>
        <td class="v1">Back</td>
        <td class="v2">Front</td>
      </tr>
      <tr>
        <td class="en">Velcro</td>
        <td class="jp">ベルクロ</td>
        <td class="v1" id="vBack">オス</td>
        <td class="v2" id="vFront">しせい</td>
      </tr>
      <tr>
        <td class="en">Skirt</td>
        <td class="jp">スカート</td>
        <td class="v1" id="kBack">あり</td>
        <td class="v2" id="kFront">なし</td>
      </tr>
      <tr>
        <td class="en">Eyelet</td>
        <td class="jp">アイレット</td>
        <td class="v1" id="eBack">P 300</td>
        <td class="v2" id="eFront">C 100</td>
      </tr>
    </table>

    <!-- バーコード -->
    <div class="barcode-wrap">
      <svg id="barcode"></svg>
      <div class="barcode-text" id="barcodeText">SDP w300xh200 0204558</div>
    </div>

    <!-- ケア表示 -->
    <div class="care">
      <div class="en">Do not wash. Do not bleach. Do not tumble dry. Do not iron. Do not dry clean.</div>
      <div class="icons">
        <!-- 防炎フレーム -->
        <svg viewBox="0 0 28 28" aria-label="防炎">
          <path d="M14 1.5 L24.5 5 V13.5 C24.5 20.5 19.5 24.8 14 27 C8.5 24.8 3.5 20.5 3.5 13.5 V5 Z" fill="#111" />
          <path
            d="M14.5 7 C12.2 10 10.5 11.8 11.4 15.2 C11.9 17.4 13.4 18.6 15 18.4 C17 18.2 18.4 16.4 18 14.2 C17.7 12.6 16.4 12.2 15.8 10.4 C15.3 11.8 14.4 11.6 14.2 10.4 C14 9.2 14.7 8.2 14.5 7 Z"
            fill="#fff" />
        </svg>
        <!-- 洗濯30 -->
        <svg viewBox="0 0 28 28" aria-label="wash30">
          <path d="M3 9 L5 22.5 H23 L25 9" fill="none" stroke="#111" stroke-width="1.5" />
          <path d="M3 9 C5.2 6.8 6.8 11 9 9 C11.2 7 12.8 11 15 9 C17.2 7 18.8 11 21 9 C23.2 7 24 10 25 9" fill="none"
            stroke="#111" stroke-width="1.5" /><text x="14" y="19.5" text-anchor="middle" font-size="8.5"
            font-weight="700" fill="#111">30</text>
        </svg>
        <!-- 漂白禁止 -->
        <svg viewBox="0 0 28 28" aria-label="no bleach">
          <path d="M14 3.5 L25 23 H3 Z" fill="none" stroke="#111" stroke-width="1.5" />
          <line x1="4" y1="5" x2="24" y2="24" stroke="#111" stroke-width="1.7" />
          <line x1="24" y1="5" x2="4" y2="24" stroke="#111" stroke-width="1.7" />
        </svg>
        <!-- タンブル乾燥禁止 -->
        <svg viewBox="0 0 28 28" aria-label="no tumble">
          <rect x="3" y="3" width="22" height="22" fill="none" stroke="#111" stroke-width="1.5" />
          <circle cx="14" cy="14" r="7" fill="none" stroke="#111" stroke-width="1.5" />
          <line x1="4" y1="4" x2="24" y2="24" stroke="#111" stroke-width="1.7" />
          <line x1="24" y1="4" x2="4" y2="24" stroke="#111" stroke-width="1.7" />
        </svg>
        <!-- アイロン禁止 -->
        <svg viewBox="0 0 28 28" aria-label="no iron">
          <path d="M3 19 H24 L21 10.5 C20.3 8.5 18 8.5 16 9.5 L3 14 Z" fill="none" stroke="#111" stroke-width="1.5" />
          <line x1="4" y1="6" x2="24" y2="22" stroke="#111" stroke-width="1.7" />
          <line x1="24" y1="6" x2="4" y2="22" stroke="#111" stroke-width="1.7" />
        </svg>
        <!-- ドライ禁止 -->
        <svg viewBox="0 0 28 28" aria-label="no dryclean">
          <circle cx="14" cy="14" r="11" fill="none" stroke="#111" stroke-width="1.5" />
          <line x1="5.5" y1="5.5" x2="22.5" y2="22.5" stroke="#111" stroke-width="1.7" />
          <line x1="22.5" y1="5.5" x2="5.5" y2="22.5" stroke="#111" stroke-width="1.7" />
        </svg>
      </div>
      <div class="jp">洗えません。漂白できません。タンブル乾燥できません。アイロンがけできません。ドライクリーニングできません。</div>
    </div>

    <!-- QR + 防炎ボックス -->
    <div class="mid">
      <div class="qr">
        <div id="qrcode"></div>
        <div class="logo">
          <!-- CDI ロゴ(簡易) -->
          <svg viewBox="0 0 40 28">
            <path d="M30 6 C26 3 18 3 14 8 C10 13 12 21 19 23 C24 24.5 29 22 31 18" fill="none" stroke="#111"
              stroke-width="3.4" stroke-linecap="round" /><text x="20" y="27" text-anchor="middle" font-size="7"
              font-weight="800" fill="#111" font-family="Arial">CDI</text>
          </svg>
        </div>
      </div>

      <div class="bohen">
        <div class="mark">
          <!-- 日本防炎協会マーク(簡易) -->
          <svg viewBox="0 0 44 30" aria-label="防炎協会">
            <path
              d="M22 2 C18 7 12 8 14 15 C9 13 8 8 8 8 C6 14 9 20 16 22 C13 23 9 22 9 22 C13 27 22 28 28 24 C34 20 35 13 31 9 C33 11 33 14 33 14 C36 9 33 4 27 4 C29 6 29 8 29 8 C28 4 25 2 22 2 Z"
              fill="#111" />
          </svg>
        </div>
        <div class="t1">防炎製品</div>
        <div class="div"></div>
        <div class="t2">事業所番号</div>
        <div class="num" id="bohenNum">B2250064</div>
        <div class="div"></div>
        <div class="t3">(公財)日本防炎協会</div>
      </div>
    </div>

    <!-- フッター -->
    <div class="foot">
      <div class="company">株式会社シーディアイ</div>
      <div class="addr">〒491-0922 愛知県一宮市大和町妙興寺字丹波12番</div>
      <div class="addr">Tel 0586-27-0123&nbsp;&nbsp;&nbsp;https://www.cdijpn.com/</div>
      <div class="design">Design and Quality CDI of JAPAN</div>
    </div>

    <!-- 余白 -->
    <div class="spacer"></div>

    <!-- ハトメ円 -->
    <div class="eyelets" id="eyelets"></div>

    <!-- 下ミシン目 -->
    <div class="perf" id="perfBottom"></div>
  </div>

  <!-- ===== ライブラリ (オフライン内蔵) ===== -->
  <script>/*! JsBarcode v3.11.6 | (c) Johan Lindell | MIT license */
