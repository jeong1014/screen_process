  <script>
    /* =====================================================================
       ★ ここを編集 — 原単タイプ / オプション / バーコード内容
       ===================================================================== */
    const FABRIC_NAMES = {
      LN: "ローノイズポリエステル生地",                 /* ※LN/SDPの和名は要確認 */
      DP: "ダブルレイヤーポリエステル生地",
      SDP: "スペシャルダブルレイヤーポリエステル生地"
    };

    const labelData = {
      fabric: "DP",                       /* 原単タイプ: LN / DP / SDP (ヘッダー・表に反映) */
      fabricNameJp: null,                 /* null=FABRIC_NAMESから自動。手動指定も可 */

      size: "W:2800×H:3000",
      velcro: { back: "オス", front: "メス" },
      skirt: { back: "あり", front: "なし" },
      eyelet: { back: "P 300", front: "C 100" },

      barcodeValue: "SDP w300xh200 0204558",   /* ← バーコード内容(変更) */
      barcodeText: null,                       /* null=barcodeValueをそのまま表示 */

      qrValue: "https://cdigolf.base.ec/",        /* ← QR内容(固定) */
      bohenNumber: "B2250064",

      eyeletCircles: 7                          /* 下部ハトメ円の数 */
    };

    /* =====================================================================
       描画ロジック(基本的に編集不要)
       ===================================================================== */
    function setText(id, v) { const el = document.getElementById(id); if (el) el.textContent = v; }

    function dots(el, n) {
      el.innerHTML = "";
      for (let i = 0; i < n; i++) { const s = document.createElement("i"); el.appendChild(s); }
    }

    function render() {
      const d = labelData;

      // ヘッダー・表
      setText("fCode", d.fabric);
      setText("fName", d.fabricNameJp || FABRIC_NAMES[d.fabric] || "");
      setText("sFabric", d.fabric);
      setText("sSize", d.size);
      setText("vBack", d.velcro.back); setText("vFront", d.velcro.front);
      setText("kBack", d.skirt.back); setText("kFront", d.skirt.front);
      setText("eBack", d.eyelet.back); setText("eFront", d.eyelet.front);
      setText("bohenNum", d.bohenNumber);
      setText("barcodeText", d.barcodeText || d.barcodeValue);

      // バーコード (Code128)
      try {
        JsBarcode("#barcode", d.barcodeValue, {
          format: "CODE128", displayValue: false, margin: 0, height: 120, width: 2
        });
      } catch (e) { console.error("barcode error:", e); }

      // QR (固定内容・誤り訂正H)
      try {
        const qr = qrcode(0, "H");
        qr.addData(d.qrValue);
        qr.make();
        document.getElementById("qrcode").innerHTML = qr.createImgTag(4, 0);
        const img = document.querySelector("#qrcode img");
        if (img) { img.style.width = "36mm"; img.style.height = "36mm"; img.style.imageRendering = "pixelated"; }
      } catch (e) { console.error("qr error:", e); }

      // ミシン目・ハトメ
      dots(document.getElementById("perfTop"), 22);
      dots(document.getElementById("perfBottom"), 22);
      const ey = document.getElementById("eyelets");
      ey.innerHTML = "";
      for (let i = 0; i < d.eyeletCircles; i++) { const s = document.createElement("i"); ey.appendChild(s); }
    }

    /* =====================================================================
       ★ 自動化: URL の /label/{バーコード} から DB を読み、ラベルを自動で埋める
          例) http://localhost:8000/label/ORD-20260713-0001-01
              末尾に ?print=1 を付けると自動で印刷ダイアログを開く
       ===================================================================== */
    async function initFromDB() {
      const parts = location.pathname.split("/").filter(Boolean);
      const bc = decodeURIComponent(parts[parts.length - 1] || "");
      if (bc && bc.toLowerCase() !== "label") {
        try {
          const r = await fetch("/api/label/" + encodeURIComponent(bc));
          if (r.ok) {
            const d = await r.json();
            Object.assign(labelData, d);
          } else { console.error("label fetch failed:", r.status); }
        } catch (e) { console.error("label fetch error:", e); }
      }
      render();
      if (new URLSearchParams(location.search).get("print") === "1") {
        setTimeout(() => window.print(), 500);
      }
    }
    document.addEventListener("DOMContentLoaded", initFromDB);
  </script>
</body>

</html>